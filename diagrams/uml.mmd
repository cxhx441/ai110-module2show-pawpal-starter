classDiagram
    class Owner {
        +str name
        +int time_available_minutes
        +list~Pet~ pets
        +Scheduler scheduler
        +add_pet()
        +remove_pet()
        +get_schedule()
    }

    class Pet {
        +str name
        +list~Task~ tasks
        +add_task()
        +remove_task()
    }

    class Task {
        +str title
        +str description
        +int priority
        +int duration
        +Frequency frequency
        +bool completed
    }

    class Frequency {
        <<enumeration>>
        DAILY
        WEEKLY
        AS_NEEDED
    }

    class ScheduledTask {
        +Task task
        +time start_time
    }

    class Scheduler {
        +int time_budget
        +list~ScheduledTask~ schedule
        +generate()
    }

    Owner "1" --> "0..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Owner --> Scheduler : uses
    Scheduler "1" --> "0..*" ScheduledTask : contains
    ScheduledTask --> Task : wraps
    Task --> Frequency : uses
