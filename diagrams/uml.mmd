classDiagram
    class Owner {
        +str name
        +list~Pet~ pets
        +generate_daily_plan()
        +add_pet()
        +remove_pet()
    }

    class Pet {
        +str name
        +list~Task~ tasks
        +add_task()
        +remove_task()
    }

    class Task {
        +str title
        +str description
        +int priority
        +int duration
    }

    class ScheduledTask {
        +Task task
        +str start_time
    }

    class DailyPlan {
        +list~ScheduledTask~ scheduled_tasks
        +generate()
    }

    Owner "1" --> "0..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Owner ..> DailyPlan : generates
    DailyPlan "1" --> "0..*" ScheduledTask : contains
    ScheduledTask --> Task : wraps
